{
  "name": "rss-trends",
  "version": "1.0.0",
  "description": "Serverless RSS trend analyzer with AI semantic analysis",
  "scripts": {
    "dev": "npx vercel@latest dev",
    "deploy": "npx vercel@latest --prod",
    "build": "tsc --noEmit",
    "test": "npx ts-node tests/test.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "rss-parser": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/rss-parser": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
